{
  "entities": {
    "User": {
      "title": "User",
      "description": "A user of the WasteWise application.",
      "type": "object",
      "properties": {
        "uid": {
          "type": "string",
          "description": "The unique identifier of the user."
        },
        "email": {
          "type": "string",
          "format": "email",
          "description": "The user's email address."
        },
        "displayName": {
          "type": "string",
          "description": "The user's display name."
        },
        "createdAt": {
          "type": "string",
          "format": "date-time",
          "description": "The timestamp when the user was created."
        }
      },
      "required": ["uid", "email", "createdAt"]
    },
    "Receipt": {
      "title": "Receipt",
      "description": "A scanned receipt containing purchased food items.",
      "type": "object",
      "properties": {
        "userId": {
          "type": "string",
          "description": "The ID of the user who scanned the receipt."
        },
        "items": {
          "type": "array",
          "description": "The food items on the receipt.",
          "items": {
            "type": "string"
          }
        },
        "createdAt": {
          "type": "string",
          "format": "date-time",
          "description": "The timestamp when the receipt was scanned."
        },
        "imageUrl": {
          "type": "string",
          "description": "The URL of the uploaded scan image."
        }
      },
      "required": ["userId", "createdAt", "items"]
    },
    "FoodScan": {
      "title": "Food Scan",
      "description": "A scanned food item.",
      "type": "object",
      "properties": {
        "userId": {
          "type": "string",
          "description": "The ID of the user who scanned the food."
        },
        "item": {
          "type": "string",
          "description": "The name of the food item."
        },
        "condition": {
          "type": "string",
          "description": "The condition of the food item."
        },
        "suggestions": {
          "type": "array",
          "description": "Suggestions for using the food.",
          "items": {
            "type": "string"
          }
        },
        "createdAt": {
          "type": "string",
          "format": "date-time",
          "description": "The timestamp when the food was scanned."
        },
        "imageUrl": {
          "type": "string",
          "description": "The URL of the uploaded scan image."
        }
      },
      "required": ["userId", "createdAt", "item", "condition", "suggestions"]
    }
  },
  "firestore": {
    "users/{userId}": {
      "schema": {
        "$ref": "#/entities/User"
      },
      "description": "Stores user profiles."
    },
    "receipts/{receiptId}": {
      "schema": {
        "$ref": "#/entities/Receipt"
      },
      "description": "Stores scanned receipts."
    },
    "food_scans/{foodScanId}": {
      "schema": {
        "$ref": "#/entities/FoodScan"
      },
      "description": "Stores scanned food items."
    }
  }
}
